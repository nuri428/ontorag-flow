# ontorag-flow configuration (copy to .env and edit).
# All variables are optional; defaults shown below.

# MCP endpoint of the sister `ontorag` server (consumed as a client).
ONTORAG_MCP_URL=http://localhost:8000/mcp

# Agent identity recorded as prov:wasAssociatedWith in every audit activity.
AGENT_ID=urn:ontorag-flow:agent:system

# SQLite file holding case state, process definitions, and the audit log.
DATABASE_PATH=ontorag_flow.db

# FastAPI server bind address.
API_HOST=0.0.0.0
API_PORT=8100

# Logging level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Decision-engine wiring. The rule engine always works; the others activate only
# when their backing client is configured here.
# LLM engine (LlmAgentEngine): set a provider to enable it.
# LLM_PROVIDER=anthropic   # anthropic | openai | ollama
# LLM_MODEL=claude-sonnet-4-6
# Bayesian engine (BayesianMpeEngine): open an ontorag MCP connection at startup.
CONNECT_ONTORAG=false
