# ontorag-flow configuration (copy to .env and edit).
# All variables are optional; defaults shown below.

# MCP endpoint of the sister `ontorag` server (consumed as a client).
ONTORAG_MCP_URL=http://localhost:8000/mcp

# Agent identity recorded as prov:wasAssociatedWith in every audit activity.
AGENT_ID=urn:ontorag-flow:agent:system

# FastAPI server bind address.
API_HOST=0.0.0.0
API_PORT=8100

# Logging level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
